{
  "name": "express-ai-desktop",
  "version": "2.1.0",
  "description": "EXPRESS-AI — Desktop Road Analytics Tool",
  "main": "main.js",
  "author": "Express AI Team",
  "license": "CC-BY-NC-4.0",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-log": "^5.1.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.expressai.desktop",
    "productName": "EXPRESS-AI",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "../dist/electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html"
    ],
    "extraResources": [
      {
        "from": "../dist/express-server",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../client/dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../../client/public/logos/express-ai-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "../../client/public/logo.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Jacob-DelosAngeles",
      "repo": "EXPRESS-AI",
      "releaseType": "release"
    }
  }
}